# Client (see client/.env.example for the authoritative client-side copy)
VITE_APP_NAME=PlacePrep
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server (see server/.env.example for the authoritative server-side copy)
APP_NAME=PlacePrep
APP_ENV=development
API_V1_PREFIX=/api/v1
# IMPORTANT: on any deployed backend (Render, etc.) this MUST be set to your
# real deployed frontend origin(s), comma-separated — e.g.
# CORS_ORIGINS=https://your-app.vercel.app
# Leaving this at the localhost default in production silently blocks every
# request from your deployed frontend.
CORS_ORIGINS=http://localhost:5173

# Supabase — current publishable/secret key system, not the deprecated
# anon/service_role naming.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=placement-pdfs

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
