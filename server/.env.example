# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored -- never commit real secrets.

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
# Optional. Vercel's generated hostnames aren't stable enough to guess with
# a prefix-anchored pattern -- confirmed on this project, the SAME app has
# shown up as both "...-client-65udk2i79.vercel.app" and "...-c.vercel.app"
# (Vercel truncates the name to fit its own length budget, unpredictably
# from outside). Trusting any single-level *.vercel.app subdomain sidesteps
# that; it's broader than "just this project", which is fine here since
# auth is Bearer-token-based, not cookie-based -- see config.py's
# CORS_ORIGIN_REGEX docstring for the full reasoning.
# CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9-]+\.vercel\.app$

# --- Supabase ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Storage ---
PDF_STORAGE_BUCKET=pdfs
MAX_PDF_SIZE_BYTES=26214400
MAX_IMAGE_SIZE_BYTES=15728640

# --- AI provider ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_CONFIDENCE_THRESHOLD=0.7
DUPLICATE_SIMILARITY_THRESHOLD=0.87
MAX_EXTRACTION_ATTEMPTS=3

# --- Chunking ---
CHUNK_MAX_CHARS=12000
CHUNK_OVERLAP_CHARS=400

# --- OCR fallback ---
OCR_ENABLED=true
OCR_MIN_CHARS_PER_PAGE=40
OCR_DPI=200

# --- Rate limiting (Phase 6) ---
# In-memory limiter -- fine for a single-process dev/small deploy. On a
# multi-instance deploy (multiple Render/Railway dynos), each instance
# tracks its own counters, so effective limits multiply by instance count.
# Swap to a Redis storage_uri (see app/core/rate_limit.py) before scaling
# horizontally.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_QUIZ_SUBMIT=30/minute
RATE_LIMIT_DEFAULT=120/minute
