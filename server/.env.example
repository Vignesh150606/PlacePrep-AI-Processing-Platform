# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- App ---
ENVIRONMENT=development
# IMPORTANT: set ENVIRONMENT=production on your deployed backend (Render).
# This also enables a startup log warning (see app/main.py) if CORS_ORIGINS
# still looks like the localhost default while ENVIRONMENT=production.
CORS_ORIGINS=http://localhost:5173

# --- Supabase ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Storage ---
PDF_STORAGE_BUCKET=pdfs
MAX_PDF_SIZE_BYTES=26214400

# --- AI provider ---
# Get a key at https://aistudio.google.com/app/apikey (Google account,
# no credit card required for the free tier). See PROJECT_STATE.md for the
# full walkthrough and current free-tier caveats.
AI_PROVIDER=gemini
GEMINI_API_KEY=
# gemini-2.0-flash was deprecated by Google in 2026 — use gemini-2.5-flash
# (current free-tier default) unless you've confirmed a newer model name
# in Google AI Studio / the Gemini API docs.
GEMINI_MODEL=gemini-2.5-flash
AI_CONFIDENCE_THRESHOLD=0.7
DUPLICATE_SIMILARITY_THRESHOLD=0.87
MAX_EXTRACTION_ATTEMPTS=3
