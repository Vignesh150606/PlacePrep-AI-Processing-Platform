# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# --- Supabase ---
# Filled in during Sprint 2 Step 3 (Supabase project setup).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Storage ---
PDF_STORAGE_BUCKET=pdfs
MAX_PDF_SIZE_BYTES=26214400

# --- AI provider (Sprint 4) ---
# See the setup guide from Claude for how to create this key.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_CONFIDENCE_THRESHOLD=0.7
DUPLICATE_SIMILARITY_THRESHOLD=0.87
MAX_EXTRACTION_ATTEMPTS=3
